{
  "compilerOptions": {
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "@assets/*" : ["assets/*"],
      "@icons/*" : ["assets/icons/*"],
      "@fonts/*" : ["assets/fonts/*"],
      "@api/*" : ["src/api/*"],
      "@components/*" : ["src/components/*"],
      "@constants/*" : ["src/constants/*"],
      "@hooks/*" : ["src/hooks/*"],
      "@navigation/*" : ["src/navigation/*"],
      "@providers/*" : ["src/providers/*"],
      "@screens/*" : ["src/screens/*"],
      "@services/*" : ["src/services/*"],
      "@stores/*" : ["src/stores/*"],
      "@styles/*" : ["src/styles/*"],
      "@types/*" : ["src/types/*"],
      "@utils/*" : ["src/utils/*"],
      "@src/*" : ["src/*"]
    }
  }
}
